// Text animation demo — comprehensive test of all WriteText / RevealText / Tex variants
// Run: cargo run -p scalar_cli -- -i test_text_anim.scl -d 28 -o text_anim_demo.mp4
//
// Requires: Roboto-Regular.ttf at assets/fonts/ (adjust path below if needed)
// Tex() uses a pure-Rust math renderer — no external tools needed!

Resolution(1280, 720)
Background(0.05, 0.05, 0.12)

SetFPS(60)

// Load font
let font = FontImport("../96a0b3c0-be13-4354-8674-72220ab22596/assets/fonts/Roboto-Regular.ttf")

// ═══════════════════════════════════════════════════════════════════════════════
// SECTION 1 — WriteText: basic fade-in per character (duration-based timing)
// ═══════════════════════════════════════════════════════════════════════════════
let title_chars = WriteText("1) WriteText (basic)",
    x: 0, y: 320,
    font: font, size: 32,
    duration: 1.5,
    easing: "ease_out_cubic",
    fill: [0.3, 0.6, 1.0, 1.0])

// ═══════════════════════════════════════════════════════════════════════════════
// SECTION 2 — WriteText: per_char override (each char shows for 0.12s)
// Short text so the total duration stays reasonable.
// ═══════════════════════════════════════════════════════════════════════════════
let per_char_chars = WriteText("2) per_char",
    x: -400, y: 260,
    font: font, size: 28,
    per_char: 0.12,
    delay: 2.0,
    easing: "ease_out_cubic",
    fill: [0.2, 1.0, 0.4, 1.0])

// ═══════════════════════════════════════════════════════════════════════════════
// SECTION 3 — WriteText with stroke (fade-in + visible outline)
// ═══════════════════════════════════════════════════════════════════════════════
let stroke_chars = WriteText("3) WriteText stroke",
    x: 0, y: 260,
    font: font, size: 28,
    duration: 1.5,
    delay: 2.0,
    easing: "ease_out_cubic",
    fill: [1.0, 0.8, 0.0, 1.0],
    stroke: [1.0, 1.0, 1.0, 0.6],
    stroke_width: 1.5)

// ═══════════════════════════════════════════════════════════════════════════════
// SECTION 4 — WriteText with bounce easing
// ═══════════════════════════════════════════════════════════════════════════════
let bounce_chars = WriteText("4) WriteText bounce",
    x: 400, y: 260,
    font: font, size: 28,
    duration: 1.8,
    delay: 2.0,
    easing: "ease_out_bounce",
    fill: [1.0, 0.4, 0.4, 1.0])

// ═══════════════════════════════════════════════════════════════════════════════
// SECTION 5 — RevealText: basic (segment_subdivisions: 1 — original behavior)
// ═══════════════════════════════════════════════════════════════════════════════
let reveal_basic = RevealText("subdiv: 1",
    x: -350, y: 80,
    font: font, size: 26,
    duration: 2.5,
    delay: 5.0,
    easing: "ease_out_cubic",
    fill: [0.3, 0.6, 1.0, 1.0],
    stroke: [0.2, 0.2, 0.2, 1.0],
    stroke_width: 1.5,
    segment_subdivisions: 1)

// ═══════════════════════════════════════════════════════════════════════════════
// SECTION 6 — RevealText: smooth (segment_subdivisions: 6)
// ═══════════════════════════════════════════════════════════════════════════════
let reveal_smooth = RevealText("subdiv: 6",
    x: 0, y: 80,
    font: font, size: 26,
    duration: 2.5,
    delay: 5.0,
    easing: "ease_out_cubic",
    fill: [0.2, 1.0, 0.4, 1.0],
    stroke: [0.2, 0.2, 0.2, 1.0],
    stroke_width: 1.5,
    segment_subdivisions: 6)

// ═══════════════════════════════════════════════════════════════════════════════
// SECTION 7 — RevealText: ultra smooth (segment_subdivisions: 12)
// ═══════════════════════════════════════════════════════════════════════════════
let reveal_ultra = RevealText("subdiv: 12",
    x: 350, y: 80,
    font: font, size: 26,
    duration: 2.5,
    delay: 5.0,
    easing: "ease_out_cubic",
    fill: [1.0, 0.8, 0.0, 1.0],
    stroke: [0.2, 0.2, 0.2, 1.0],
    stroke_width: 1.5,
    segment_subdivisions: 12)

// Label the comparison row
let reveal_label = Text("RevealText comparison (subdiv: 1  |  6  |  12)",
    x: 0, y: 130,
    font: font, size: 14,
    fill: [0.5, 0.5, 0.7, 1.0])
FadeIn(reveal_label, duration: 0.5, delay: 5.0, easing: "ease_out_sine")

// ═══════════════════════════════════════════════════════════════════════════════
// SECTION 8 — RevealText: per_char + delay + custom stroke
// ═══════════════════════════════════════════════════════════════════════════════
let reveal_delayed = RevealText("8) RevealText per_char + delay",
    x: 0, y: 0,
    font: font, size: 26,
    per_char: 0.25,
    delay: 8.5,
    easing: "ease_out_sine",
    fill: [1.0, 0.4, 1.0, 1.0],
    stroke: [0.5, 0.5, 0.5, 1.0],
    stroke_width: 1.5,
    segment_subdivisions: 6)

// ═══════════════════════════════════════════════════════════════════════════════
// SECTION 9 — RevealText: thin characters that benefit most from subdivision
// (letters like "l", "i", "t" have few path segments → subdivision helps)
// ═══════════════════════════════════════════════════════════════════════════════
let thin_chars = RevealText("9) thin chars: l i l i l i  |  subdiv: 8",
    x: 0, y: -80,
    font: font, size: 30,
    duration: 3.0,
    delay: 11.5,
    easing: "ease_out_cubic",
    fill: [0.3, 0.6, 1.0, 1.0],
    stroke: [0.2, 0.2, 0.2, 1.0],
    stroke_width: 2.0,
    segment_subdivisions: 8)

// ═══════════════════════════════════════════════════════════════════════════════
// SECTION 10 — WriteText vs RevealText side-by-side comparison
// ═══════════════════════════════════════════════════════════════════════════════
let comp_fade = WriteText("WriteText",
    x: -200, y: -190,
    font: font, size: 22,
    duration: 1.0,
    delay: 15.5,
    easing: "ease_out_cubic",
    fill: [0.3, 0.6, 1.0, 1.0])

let comp_reveal = RevealText("RevealText",
    x: 100, y: -190,
    font: font, size: 22,
    duration: 1.5,
    delay: 15.5,
    easing: "ease_out_cubic",
    fill: [1.0, 0.8, 0.0, 1.0],
    stroke: [0.2, 0.2, 0.2, 1.0],
    stroke_width: 1.0,
    segment_subdivisions: 6)

// Label the comparison
let comp_label = Text("WriteText vs RevealText (same timing)",
    x: 0, y: -145,
    font: font, size: 13,
    fill: [0.5, 0.5, 0.7, 1.0])
FadeIn(comp_label, duration: 0.5, delay: 15.5, easing: "ease_out_sine")

// ═══════════════════════════════════════════════════════════════════════════════
// SECTION 11 — Credits (FadeIn / FadeOut)
// ═══════════════════════════════════════════════════════════════════════════════
let credits = Text("WriteText / RevealText / per_char / delay / segment_subdivisions / stroke / easing",
    x: 0, y: -270,
    font: font, size: 16,
    fill: [0.5, 0.5, 0.6, 1.0])

FadeIn(credits, duration: 1.0, delay: 17.5, easing: "ease_out_sine")
FadeOut(credits, duration: 1.0, delay: 18.5, easing: "ease_in_sine")

// ═══════════════════════════════════════════════════════════════════════════════
// SECTION 12 — LaTeX: simple equation (per-glyph Animate with stagger)
// ═══════════════════════════════════════════════════════════════════════════════
// Animate() handles per-element stagger automatically — no for-loop needed!
let eq1 = Tex("E = mc^2",
    x: -350, y: 240,
    fill: [0.3, 0.6, 1.0, 1.0])
Animate(eq1, "FadeIn", duration: 0.25, stagger: 0.08, delay: 19.5,
    easing: "ease_out_cubic")

// ═══════════════════════════════════════════════════════════════════════════════
// SECTION 13 — LaTeX: integral with stroke (per-glyph Animate with stagger)
// ═══════════════════════════════════════════════════════════════════════════════
let eq2 = Tex("\\int_{0}^{\\infty} e^{-x^2} dx = \\frac{\\sqrt{\\pi}}{2}",
    x: 0, y: 240,
    fill: [1.0, 0.8, 0.2, 1.0],
    stroke: [0.5, 0.5, 0.5, 1.0],
    stroke_width: 0.5)
Animate(eq2, "FadeIn", duration: 0.2, stagger: 0.06, delay: 20.0,
    easing: "ease_out_sine")

// ═══════════════════════════════════════════════════════════════════════════════
// SECTION 14 — LaTeX: summation (per-glyph Animate with tighter stagger)
// ═══════════════════════════════════════════════════════════════════════════════
let eq3 = Tex("\\sum_{n=1}^{\\infty} \\frac{1}{n^2} = \\frac{\\pi^2}{6}",
    x: 350, y: 240,
    fill: [0.2, 1.0, 0.4, 1.0])
Animate(eq3, "FadeIn", duration: 0.15, stagger: 0.04, delay: 20.5,
    easing: "ease_out_cubic")

// ═══════════════════════════════════════════════════════════════════════════════
// SECTION 15 — LaTeX: lim with per-glyph DrawThenFill
// ═══════════════════════════════════════════════════════════════════════════════
let eq4 = Tex("\\lim_{x \\to 0} \\frac{\\sin x}{x} = 1",
    x: 0, y: 160,
    fill: [1.0, 0.4, 0.4, 1.0])
Animate(eq4, "DrawThenFill", duration: 0.4, stagger: 0.1, delay: 22.0,
    fill: [1.0, 0.4, 0.4, 1.0])

// ═══════════════════════════════════════════════════════════════════════════════
// SECTION 16 — LaTeX: matrix (per-glyph FadeIn with fine stagger)
// ═══════════════════════════════════════════════════════════════════════════════
let eq5 = Tex("\\begin{bmatrix} a & b \\\\ c & d \\end{bmatrix}^{-1} = \\frac{1}{ad-bc} \\begin{bmatrix} d & -b \\\\ -c & a \\end{bmatrix}",
    x: 0, y: 80,
    fill: [0.6, 0.4, 1.0, 1.0])
Animate(eq5, "FadeIn", duration: 0.25, stagger: 0.05, delay: 24.0,
    easing: "ease_out_cubic")

// ═══════════════════════════════════════════════════════════════════════════════
// End note
// ═══════════════════════════════════════════════════════════════════════════════
let end_note = Text("Expected duration: ~28s  |  Tex() uses RaTeX (pure-Rust math renderer)",
    x: 0, y: -320,
    font: font, size: 13,
    fill: [0.3, 0.3, 0.4, 1.0])
FadeIn(end_note, duration: 0.5, delay: 26.5, easing: "ease_out_sine")
