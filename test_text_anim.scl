// Morph() animation demo — shapes and LaTeX morphing
// Run: cargo run -p scalar_cli -- -i test_text_anim.scl -d 9 -o morph_demo.mp4
//
// Morph() works with ANY node that has PathData:
//   - Shapes: Circle, Rect, Polygon, Star, Triangle, etc.
//   - LaTeX via Tex() (RaTeX pure-Rust math renderer)
//
// After morph completes, the original target shape is restored exactly.
// The source is auto-hidden when morph starts.
// Both Morph() and Animate("Morph") accept single NodeId or [NodeId].

Resolution(1280, 720)
Background(0.05, 0.05, 0.12)
SetFPS(60)

// Font for labels
let font = FontImport("../96a0b3c0-be13-4354-8674-72220ab22596/assets/fonts/Roboto-Regular.ttf")

// ─────────────────────────────────────────────────────────────────────────────
// SECTION 1 — Shape morph: Circle → Rect (standalone Morph())
// ─────────────────────────────────────────────────────────────────────────────

let s1_title = Text("1) Circle → Rect",
    x: -500, y: 280,
    font: font, size: 22,
    fill: [0.5, 0.5, 0.8, 1.0])
FadeIn(s1_title, duration: 0.3, delay: 0.0, easing: "ease_out_sine")

// Source: blue circle at left
let circle = Circle(-250, 100, 60,
    fill: [0.3, 0.6, 1.0, 1.0],
    stroke: [0.5, 0.5, 0.5, 1.0],
    stroke_width: 2.0)

// Target: green rect at same position (hidden initially)
let rect = Rect(-250, 100, 120, 100,
    fill: [0.2, 1.0, 0.4, 1.0],
    stroke: [0.5, 0.5, 0.5, 1.0],
    stroke_width: 2.0)
SetVisibility(rect, false)

// Morph rect from circle — circle auto-hides when morph starts,
// rect path is restored to exact original on completion.
Morph(rect, circle, duration: 1.0, delay: 0.8, easing: "ease_in_out_cubic")

// ─────────────────────────────────────────────────────────────────────────────
// SECTION 2 — Shape morph: Star → Triangle
// ─────────────────────────────────────────────────────────────────────────────

let s2_title = Text("2) Star → Triangle",
    x: 100, y: 280,
    font: font, size: 22,
    fill: [0.5, 0.5, 0.8, 1.0])
FadeIn(s2_title, duration: 0.3, delay: 2.5, easing: "ease_out_sine")

// Source: yellow star
let star = Star(100, 100, 60, 30, 5,
    fill: [1.0, 0.8, 0.2, 1.0],
    stroke: [0.5, 0.5, 0.5, 1.0],
    stroke_width: 2.0)

// Target: purple triangle (hidden initially)
let triangle = Triangle(100, 100, 80,
    fill: [0.6, 0.4, 1.0, 1.0],
    stroke: [0.5, 0.5, 0.5, 1.0],
    stroke_width: 2.0)
SetVisibility(triangle, false)

Morph(triangle, star, duration: 1.0, delay: 3.3, easing: "ease_in_out_cubic")

// ─────────────────────────────────────────────────────────────────────────────
// SECTION 3 — LaTeX morph via Animate dispatcher
// E = mc² morphs into √π/2 with source auto-hidden.
// ─────────────────────────────────────────────────────────────────────────────

let s3_title = Text("3) LaTeX morph via Animate(\"Morph\")",
    x: -500, y: 50,
    font: font, size: 22,
    fill: [0.5, 0.5, 0.8, 1.0])
FadeIn(s3_title, duration: 0.3, delay: 5.5, easing: "ease_out_sine")

// Source LaTeX (gold)
let src_tex = Tex("E = mc^2",
    x: -250, y: -60,
    fill: [1.0, 0.8, 0.2, 1.0])

// Target LaTeX (purple, hidden)
let tgt_tex = Tex("\\frac{\\sqrt{\\pi}}{2}",
    x: -250, y: -60,
    fill: [0.6, 0.4, 1.0, 1.0])
SetVisibility(tgt_tex, false)

// Animate morph via the universal dispatcher
Animate(tgt_tex, "Morph", into: src_tex, duration: 1.2, delay: 6.3,
    easing: "ease_in_out_cubic")

// ─────────────────────────────────────────────────────────────────────────────
// SECTION 4 — Shape morph via Animate dispatcher: Polygon → Star
// ─────────────────────────────────────────────────────────────────────────────

let s4_title = Text("4) Animate Polygon → Star via dispatcher",
    x: 100, y: 50,
    font: font, size: 22,
    fill: [0.5, 0.5, 0.8, 1.0])
FadeIn(s4_title, duration: 0.3, delay: 5.5, easing: "ease_out_sine")

// Source: cyan hexagon
let hexagon = RegularPolygon(100, -60, 50, 6,
    fill: [0.3, 0.8, 1.0, 1.0],
    stroke: [0.5, 0.5, 0.5, 1.0],
    stroke_width: 2.0)

// Target: pink star (hidden)
let pink_star = Star(100, -60, 55, 25, 6,
    fill: [1.0, 0.4, 0.7, 1.0],
    stroke: [0.5, 0.5, 0.5, 1.0],
    stroke_width: 2.0)
SetVisibility(pink_star, false)

Animate(pink_star, "Morph", into: hexagon, duration: 1.0, delay: 6.3,
    easing: "ease_in_out_cubic")

// ─────────────────────────────────────────────────────────────────────────────
// SECTION 5 — Per-glyph text morph: "Hello" → "World" via Animate dispatcher
// ─────────────────────────────────────────────────────────────────────────────

let s5_title = Text("5) Text morph: Hello → World (per-glyph!)",
    x: -500, y: -150,
    font: font, size: 22,
    fill: [0.5, 0.5, 0.8, 1.0])
FadeIn(s5_title, duration: 0.3, delay: 8.0, easing: "ease_out_sine")

// Source text: "Hello" rendered per-glyph (gold)
// Text() now returns [NodeId] — each character is an independent shape.
let src_hello = Text("Hello",
    x: -200, y: -220,
    font: font, size: 64,
    fill: [1.0, 0.8, 0.2, 1.0])

// Target text: "World" rendered per-glyph (purple, hidden)
let tgt_world = Text("World",
    x: -200, y: -220,
    font: font, size: 64,
    fill: [0.6, 0.4, 1.0, 1.0])
SetVisibility(tgt_world, false)

// Morph each glyph pair via Animate dispatcher.
// Since Text() returns [NodeId], each character in "World" pairs with
// the corresponding character in "Hello": H→W, e→o, l→r, l→l, o→d
Animate(tgt_world, "Morph", into: src_hello, duration: 1.2, delay: 8.8,
    easing: "ease_in_out_cubic")

// ─────────────────────────────────────────────────────────────────────────────
// End note
// ─────────────────────────────────────────────────────────────────────────────
let end_note = Text("Morph auto-hides source & restores target  |  Text morph!  |  ~11s",
    x: 0, y: -310,
    font: font, size: 13,
    fill: [0.3, 0.3, 0.4, 1.0])
FadeIn(end_note, duration: 0.5, delay: 10.5, easing: "ease_out_sine")
