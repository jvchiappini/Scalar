// =======================================================
// SCALAR v11: SISTEMA DE ANIMACIÓN (SEQUENCER) & OO SYNTAX
// =======================================================

clear_scene()

// 1. CREACIÓN DE OBJETOS USANDO SINTAXIS OO
// En v11, los métodos se llaman directamente sobre el objeto: objeto.metodo()
let s1 = Sphere(0, 0, 0, 1.5)
s1.set_color(1, 0.2, 0.2, 1) // Rojo vibrante
s1.set_shadow_caster(1)

let ground = Rect(0, -2, 0, 20, 20)
ground.set_color(0.2, 0.2, 0.2, 1)
ground.set_position(0, -2.5, 0)

// 2. PROGRAMACIÓN DE ANIMACIONES (DECLARATION PHASE)
// El script se ejecuta una sola vez al inicio para llenar la línea de tiempo.

// Animación inicial: Subida con suavizado cúbico y expansión con rebote
s1.animate("y", 4.0, 2.0, "easeInOutCubic")
s1.animate("scale", 2.5, 2.0, "elasticOut")

// Esperamos 2 segundos antes de la siguiente acción
wait(2.0)

// Cambio de color progresivo a azul
s1.animate("r", 0.0, 1.5, "linear")
s1.animate("g", 0.5, 1.5, "linear")
s1.animate("b", 1.0, 1.5, "linear")

wait(1.5)

// Final: Desvanecimiento y caída rápida
s1.animate("y", 0.0, 1.0, "easeInOutCubic")
s1.animate("opacity", 0.0, 1.0, "linear")

// 3. OBJETOS SECUNDARIOS
let c1 = Cube(-10, 2, -5)
c1.set_color(0, 1, 0.5, 1)

// Comienza una animación en paralelo (ya pasamos 3.5s de wait en total)
wait(0.5) 
c1.animate("x", 10, 4.0, "easeInOutCubic")
c1.animate("scale", 0.2, 4.0, "linear")